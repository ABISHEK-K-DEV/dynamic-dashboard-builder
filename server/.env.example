# Server port (Railway/Render set PORT automatically)
PORT=5000
NODE_ENV=development

# --- Database (pick ONE approach) ---

# Option A: single URL (Railway MySQL, PlanetScale, Render MySQL)
# DATABASE_URL=mysql://user:password@host:3306/dynamic_dashboard

# Option B: individual variables (local / some hosts)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=your_password
DB_NAME=dynamic_dashboard

# Enable SSL for hosted MySQL (Railway public URL, PlanetScale, etc.)
DB_SSL=true
# Required for Railway public network (Render → Railway). Omit or set false.
DB_SSL_REJECT_UNAUTHORIZED=false

# --- CORS (required in production) ---
# Comma-separated frontend URLs (no trailing slash)
# CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# --- Optional ---
# SYNC_DB=false
# SEED_DASHBOARD=false
# DEFAULT_DASHBOARD_ID=d1
# UPLOADS_DIR=/data/uploads
